def to_rank(series):
    """Percentile rank within the corpus, NaN-safe.

    NaN values get the neutral rank 0.5 rather than poisoning the average.
    """
    r = series.rank(pct=True)
    return r.fillna(0.5)


def build_score(df, features, sign, weights=None):
    """Combine features into a difficulty score in [0, 1]. NaN-safe."""
    ranks = []
    used_weights = []
    for f in features:
        if f not in df.columns:
            continue
        r = to_rank(df[f])
        if sign[f] < 0:
            r = 1.0 - r
        w = weights[f] if weights else 1.0
        ranks.append(r * w)
        used_weights.append(w)
    if not ranks:
        raise ValueError("no usable features")
    return sum(ranks) / sum(used_weights)


