

import numpy as np
import pandas as pd
from scipy.stats import spearmanr


# --- Core features: fully language-agnostic, no external resource ---

CORE_FEATURES = ["compression", "hyp_words", "repetition_2g", "words_per_sec"]

# --- Linguistic layer: needs a per-language lexicon / LM ---

LING_FEATURES = ["oov_rate", "perplexity"]


def to_rank(series):
    """Percentile rank within the corpus. Neutralizes level shifts across
    language, VAD, model — the key to cross-corpus transfer."""
    return series.rank(pct=True)


def build_score(df, features, weights=None):
    """Combine features into a difficulty score in [0, 1].

    Each feature is turned into a percentile rank, sign-aligned so that higher
    always means harder, then averaged. No weights are learned — with ~500
    points and correlated features, a fixed average is more honest than a
    fitted model and transfers without retraining.
    """
    ranks = []
    for f in features:
        r = to_rank(df[f])
        # align sign: features negatively correlated with difficulty get flipped
        if SIGN[f] < 0:
            r = 1.0 - r
        ranks.append(r * (weights[f] if weights else 1.0))
    total_w = sum(weights.values()) if weights else len(features)
    return sum(ranks) / total_w


# sign of each feature's correlation with difficulty, from the validation tables
SIGN = {
    "compression": +1,
    "hyp_words": +1,
    "repetition_2g": +1,
    "words_per_sec": -1,
    "oov_rate": +1,
    "perplexity": +1,
}




def evaluate_score(df, targets, label=""):
    """Score both levels and report Spearman against each target."""
    df = df.copy()
    df["score_core"] = build_score(df, CORE_FEATURES)

    ling_available = [f for f in LING_FEATURES if f in df.columns and df[f].notna().any()]
    if ling_available:
        df["score_full"] = build_score(df, CORE_FEATURES + ling_available)

    print(f"=== {label} ===")
    for target in targets:
        sub = df[df[target].notna()]
        rho_core = spearmanr(sub["score_core"], sub[target])[0]
        line = f"  {target:12s}  core={rho_core:+.3f}"
        if "score_full" in df.columns:
            rho_full = spearmanr(sub["score_full"], sub[target])[0]
            line += f"  full={rho_full:+.3f}"
        print(line)
    return df



