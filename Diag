"""
alignment_metrics.py

Measure human ↔ LLM-as-a-judge alignment (one human annotator, one judge).
Metrics: only well-established standards from the literature.
"""
import numpy as np
import pandas as pd
from scipy import stats
from sklearn.metrics import cohen_kappa_score, confusion_matrix, matthews_corrcoef


# ---------------------------------------------------------------------------
# Abstention handling
# ---------------------------------------------------------------------------
def _apply_abstention(human, judge, scale, mode, abstention_value=None):
    """Apply the abstention strategy. Returns (human, judge, n_abstain, n_total)."""
    human = np.asarray(human)
    judge = np.asarray(judge, dtype=object)
    n_total = len(human)

    if abstention_value is None:
        mask = np.array([
            (j is None) or (isinstance(j, float) and np.isnan(j))
            for j in judge
        ])
    else:
        mask = judge == abstention_value
    n_abstain = int(mask.sum())

    if mode == "ignore":
        keep = ~mask
        return human[keep], judge[keep], n_abstain, n_total

    if mode == "disagree":
        judge_out = judge.copy()
        idx = np.where(mask)[0]
        if scale == "binary":
            for i in idx:
                judge_out[i] = 1 - int(human[i])
        elif scale == "ordinal":
            observed = np.unique(human[~mask].astype(int)) if (~mask).any() else np.array([0, 1])
            for i in idx:
                h = int(human[i])
                judge_out[i] = int(observed[np.argmax(np.abs(observed - h))])
        elif scale == "nominal":
            for i in idx:
                judge_out[i] = "__ABSTAIN__"
        else:
            raise ValueError("The 'disagree' mode is not defined on a continuous scale.")
        return human, judge_out, n_abstain, n_total

    if mode == "category":
        if scale != "nominal":
            raise ValueError("The 'category' mode only applies to a nominal scale.")
        judge_out = judge.copy()
        judge_out[mask] = "__ABSTAIN__"
        return human, judge_out, n_abstain, n_total

    raise ValueError(f"Unknown abstention mode: {mode}")


def _lin_ccc(x, y):
    """Concordance Correlation Coefficient (Lin, 1989)."""
    x, y = np.asarray(x, dtype=float), np.asarray(y, dtype=float)
    mx, my = x.mean(), y.mean()
    vx, vy = x.var(), y.var()
    cov = np.mean((x - mx) * (y - my))
    denom = vx + vy + (mx - my) ** 2
    return float("nan") if denom == 0 else 2 * cov / denom


# ---------------------------------------------------------------------------
# A) Global metrics
# ---------------------------------------------------------------------------
def alignment_summary(
    human_scores,
    judge_scores,
    scale,
    abstention_mode="ignore",
    abstention_value=None,
    ordinal_weights="quadratic",
):
    """
    Return a dict of global agreement metrics.

    Primary metric:
      - binary     : Cohen's κ  (φ / MCC reported separately)
      - nominal    : Cohen's κ
      - ordinal    : Weighted Cohen's κ (quadratic by default)
      - continuous : Lin's CCC  (Pearson r reported separately)
    """
    human, judge, n_abstain, n_total = _apply_abstention(
        human_scores, judge_scores, scale, abstention_mode, abstention_value
    )
    n_used = len(human)
    coverage = n_used / n_total if n_total else 0.0

    out = {
        "scale": scale,
        "abstention_mode": abstention_mode,
        "n_total": n_total,
        "n_used": n_used,
        "n_abstentions": n_abstain,
        "coverage": coverage,
    }

    if scale == "binary":
        h, j = human.astype(int), judge.astype(int)
        out.update({
            "primary_metric": "cohen_kappa",
            "value": float(cohen_kappa_score(h, j)),
            "phi_mcc": float(matthews_corrcoef(h, j)),
            "confusion_matrix": confusion_matrix(h, j, labels=[0, 1]).tolist(),
            "human_positive_rate": float(h.mean()),
            "judge_positive_rate": float(j.mean()),
        })

    elif scale == "nominal":
        labels = sorted(set(human.tolist()) | set(judge.tolist()), key=str)
        out.update({
            "primary_metric": "cohen_kappa",
            "value": float(cohen_kappa_score(human, judge)),
            "confusion_matrix": confusion_matrix(human, judge, labels=labels).tolist(),
            "labels": [str(l) for l in labels],
        })

    elif scale == "ordinal":
        h, j = human.astype(int), judge.astype(int)
        labels = sorted(set(h.tolist()) | set(j.tolist()))
        signed_err = j - h
        out.update({
            "primary_metric": f"cohen_kappa_{ordinal_weights}",
            "value": float(cohen_kappa_score(h, j, weights=ordinal_weights)),
            "confusion_matrix": confusion_matrix(h, j, labels=labels).tolist(),
            "labels": labels,
            "mean_signed_error": float(signed_err.mean()),
            "mean_absolute_error": float(np.abs(signed_err).mean()),
        })

    elif scale == "continuous":
        h, j = human.astype(float), judge.astype(float)
        r, _ = stats.pearsonr(h, j)
        diff = j - h
        out.update({
            "primary_metric": "lin_ccc",
            "value": float(_lin_ccc(h, j)),
            "pearson_r": float(r),
            "mean_signed_error": float(diff.mean()),
            "mean_absolute_error": float(np.abs(diff).mean()),
        })

    else:
        raise ValueError(f"Unknown scale: {scale}")

    return out


# ---------------------------------------------------------------------------
# B) Per-instance analysis
# ---------------------------------------------------------------------------
def alignment_dataframe(
    human_scores,
    judge_scores,
    scale,
    abstention_mode="ignore",
    abstention_value=None,
    tolerance=0,
):
    """
    DataFrame with one row per instance and its alignment status.

    Columns by scale:
      - binary/nominal : index, human, judge, aligned
      - ordinal        : index, human, judge, signed_error, absolute_error, aligned
      - continuous     : index, human, judge, difference, absolute_error, aligned

    `tolerance`: accepted absolute-error threshold (ordinal / continuous). 0 = strict agreement.
    """
    human, judge, _, _ = _apply_abstention(
        human_scores, judge_scores, scale, abstention_mode, abstention_value
    )
    df = pd.DataFrame({"index": np.arange(len(human)), "human": human, "judge": judge})

    if scale in ("binary", "nominal"):
        df["aligned"] = df["human"] == df["judge"]

    elif scale == "ordinal":
        h, j = df["human"].astype(int), df["judge"].astype(int)
        df["signed_error"] = j - h
        df["absolute_error"] = df["signed_error"].abs()
        df["aligned"] = df["absolute_error"] <= tolerance

    elif scale == "continuous":
        h, j = df["human"].astype(float), df["judge"].astype(float)
        df["difference"] = j - h
        df["absolute_error"] = df["difference"].abs()
        df["aligned"] = df["absolute_error"] <= tolerance

    else:
        raise ValueError(f"Unknown scale: {scale}")

    return df


if __name__ == "__main__":
    rng = np.random.default_rng(0)
    human = rng.integers(0, 2, size=200)
    judge = human.copy()
    flip = rng.random(200) < 0.15
    judge[flip] = 1 - judge[flip]

    print(alignment_summary(human, judge, scale="binary"))
    print(alignment_dataframe(human, judge, scale="binary").head())
