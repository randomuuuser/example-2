# EXEMPLE
# --------------------------------------------------------------------------- #
if __name__ == "__main__":
    demo = {
        "trustworthiness": 0.92,
        "continuity": 0.90,
        "neighborhood_hit": 0.63,
        "shepard_spearman": 0.41,
        "normalized_stress": 0.28,
        "silhouette": -0.082,
    }
    diagnostic(demo, n_classes=6)
