def call_level_features(sample, min_speech_ratio=0.01):
    """Acoustic features over a whole call, computed per channel.

    Speech regions come from the ground-truth segment boundaries, concatenated
    per channel. Stereo -> features on both channels; the aggregate keeps the
    worst value, since call WER is driven by the harder channel.
    """
    channels, sr = load_audio(sample["path_audio"])
    ch_map = {sample["channel_client"]: 0, sample["channel_operator"]: 1}

    gt_segs = extract_segments(sample, "label")
    duration_total = len(channels[0]) / sr

    per_channel = {}
    for ch_value, ch_idx in ch_map.items():
        if ch_idx >= len(channels):
            continue
        x = channels[ch_idx]

        # concatenate speech regions for this channel
        parts = [
            x[int(s["start_time"] * sr):int(s["end_time"] * sr)]
            for s in gt_segs if s["channel"] == ch_value
        ]
        parts = [p for p in parts if len(p) > 0]
        if not parts:
            continue

        speech = np.concatenate(parts)
        speech_duration = len(speech) / sr
        if speech_duration / duration_total < min_speech_ratio:
            continue

        rms = np.sqrt(np.mean(speech ** 2))
        per_channel[ch_idx] = {
            "c50": estimate_c50(speech, sr),
            "rms_db": 20 * np.log10(rms + 1e-10),
            "speech_ratio": speech_duration / duration_total,
            "n_segments": len(parts),
        }

    if not per_channel:
        return None

    # aggregate: worst channel for quality, sum/mean for the rest
    c50_values = [v["c50"] for v in per_channel.values() if v["c50"] is not None]
    return {
        "c50_min": min(c50_values) if c50_values else None,
        "c50_mean": float(np.mean(c50_values)) if c50_values else None,
        "rms_db_min": min(v["rms_db"] for v in per_channel.values()),
        "speech_ratio_total": sum(v["speech_ratio"] for v in per_channel.values()),
        "duration": duration_total,
        "n_channels": len(per_channel),
    }


