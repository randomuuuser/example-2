import numpy as np


def energy_envelope(x, sr, frame_ms=10):
    """Short-time energy envelope in dB."""
    frame = int(sr * frame_ms / 1000)
    n_frames = len(x) // frame
    if n_frames < 10:
        return None
    frames = x[:n_frames * frame].reshape(n_frames, frame)
    energy = np.sum(frames ** 2, axis=1)
    return 10 * np.log10(energy + 1e-12)


def estimate_c50(x, sr, frame_ms=10, min_decay_frames=5):
    """Blind C50 estimate from energy decay slopes.

    Finds monotonically decaying stretches in the energy envelope, fits a slope
    to each, and converts the median decay rate into a clarity index.
    Higher C50 = clearer, less reverberant.
    """
    env = energy_envelope(x, sr, frame_ms)
    if env is None:
        return None

    # only consider decays starting from reasonably loud frames
    threshold = np.percentile(env, 60)

    slopes = []
    i = 0
    while i < len(env) - min_decay_frames:
        if env[i] < threshold:
            i += 1
            continue
        # extend while energy keeps dropping
        j = i
        while j + 1 < len(env) and env[j + 1] < env[j]:
            j += 1
        if j - i >= min_decay_frames:
            y = env[i:j + 1]
            t = np.arange(len(y)) * frame_ms / 1000.0
            slope = np.polyfit(t, y, 1)[0]  # dB per second
            if slope < 0:
                slopes.append(slope)
            i = j + 1
        else:
            i += 1

    if len(slopes) < 3:
        return None

    median_slope = np.median(slopes)          # dB/s, negative
    t60 = -60.0 / median_slope                # seconds to drop 60 dB
    t60 = np.clip(t60, 0.05, 3.0)

    # Under an exponential decay model, energy ratio before/after 50 ms
    decay_rate = 6.9078 / t60                 # ln(1000)/T60
    early = 1.0 - np.exp(-decay_rate * 0.050)
    late = np.exp(-decay_rate * 0.050)
    return 10 * np.log10(early / late)



