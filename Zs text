import re
import unicodedata


def normalize_text(text):
    """Lowercase, strip accents, remove punctuation, collapse whitespace.

    Must stay consistent with the transforms used for WER computation.
    """
    text = text.lower()
    text = unicodedata.normalize("NFD", text)
    text = "".join(c for c in text if unicodedata.category(c) != "Mn")
    text = re.sub(r"[^\w\s]", " ", text)
    return re.sub(r"\s+", " ", text).strip()



def evaluate_features(df, features, targets=("wer_ft", "wer_zs", "difficulty"),
                      consensus_col="consensus", min_n=30):
    """Spearman correlation of each feature against each target.

    Also reports the correlation restricted to consensus segments, where both
    models agree on the difficulty tercile — the subset where an intrinsic
    (model-agnostic) signal can be demonstrated.

    Returns a DataFrame indexed by feature.
    """
    records = []
    for feat in features:
        cols = [feat, *targets]
        if consensus_col in df.columns:
            cols.append(consensus_col)
        sub = df[cols].dropna(subset=[feat, *targets])
        if len(sub) < min_n:
            continue

        rec = {"feature": feat, "n": len(sub)}
        for target in targets:
            rho, p = spearmanr(sub[feat], sub[target])
            rec[f"rho_{target}"] = rho
            rec[f"p_{target}"] = p

        if consensus_col in sub.columns:
            cons = sub[sub[consensus_col]]
            if len(cons) >= min_n:
                rho, p = spearmanr(cons[feat], cons["difficulty"])
                rec["rho_consensus"] = rho
                rec["p_consensus"] = p
                rec["n_consensus"] = len(cons)

        records.append(rec)

    out = pd.DataFrame(records).set_index("feature")
    return out.reindex(out["rho_wer_ft"].abs().sort_values(ascending=False).index)

