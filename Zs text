import gzip
import re
from collections import Counter


def compression_ratio(text):
    """Whisper's degeneration heuristic. High = repetitive output."""
    if len(text) < 10:
        return None
    raw = text.encode("utf-8")
    return len(raw) / len(gzip.compress(raw))


def repetition_rate(words, n=3):
    """Fraction of n-grams that are duplicates."""
    if len(words) < n + 1:
        return 0.0
    grams = [tuple(words[i:i + n]) for i in range(len(words) - n + 1)]
    counts = Counter(grams)
    return 1.0 - len(counts) / len(grams)


