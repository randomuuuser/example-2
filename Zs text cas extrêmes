def load_wer_series(json_path):
    """Charge le WER par appel : Series indexée par nom d'audio,
    dernière ligne (moyenne) retirée."""
    with open(json_path, "r", encoding="utf-8") as f:
        data = json.load(f)
    df = pd.DataFrame(data["WER"]["by_transcription"]).iloc[:-1]
    return df[df.columns[0]]


