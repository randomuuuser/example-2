# ============================================================
# 2. Agréger les scores segment -> appel
# ============================================================

def aggregate_to_call(df_seg, score_col="score_full", weight_col="n_ref"):
    """Un appel est difficile s'il CONTIENT des segments difficiles :
    les percentiles hauts comptent plus que la moyenne."""
    rows = []
    for sid, g in df_seg.groupby("sample_id"):
        s = g[score_col].dropna()
        if len(s) == 0:
            continue
        w = g.loc[s.index, weight_col]
        rows.append({
            "sample_id": sid,
            "score_mean": s.mean(),
            "score_wmean": np.average(s, weights=w) if w.sum() > 0 else s.mean(),
            "score_p75": s.quantile(0.75),
            "score_p90": s.quantile(0.90),
            "score_max": s.max(),
            "n_segments": len(s),
        })
    return pd.DataFrame(rows).set_index("sample_id")


