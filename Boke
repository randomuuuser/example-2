import json
import pandas as pd
from pydantic import BaseModel
from openai import OpenAI

from deepeval.models import DeepEvalBaseLLM
from deepeval.metrics import SummarizationMetric, GEval
from deepeval.test_case import LLMTestCase, LLMTestCaseParams


# --- 1. Juge custom vLLM (endpoint OpenAI-compatible, avec support schema) ---
class VLLMJudge(DeepEvalBaseLLM):
    def __init__(
        self,
        model_name="google/gemma-2-9b-it",
        base_url="http://localhost:8000/v1",
        api_key="EMPTY",
    ):
        self.model_name = model_name
        self.client = OpenAI(base_url=base_url, api_key=api_key)

    def load_model(self):
        return self.client

    def generate(self, prompt: str, schema: BaseModel = None):
        if schema is not None:
            # guided decoding via vLLM : force une sortie JSON conforme au schema
            resp = self.client.chat.completions.create(
                model=self.model_name,
                messages=[{"role": "user", "content": prompt}],
                temperature=0,
                extra_body={"guided_json": schema.model_json_schema()},
            )
            content = resp.choices[0].message.content
            return schema(**json.loads(content))
        else:
            resp = self.client.chat.completions.create(
                model=self.model_name,
                messages=[{"role": "user", "content": prompt}],
                temperature=0,
            )
            return resp.choices[0].message.content

    async def a_generate(self, prompt: str, schema: BaseModel = None):
        # mode séquentiel : on réutilise la version sync
        return self.generate(prompt, schema)

    def get_model_name(self):
        return self.model_name


judge = VLLMJudge()


# --- 2. Métriques ---
summarization = SummarizationMetric(
    threshold=0.5,
    model=judge,
    n=5,  # nombre de questions d'évaluation générées
)

faithfulness = GEval(
    name="Faithfulness",
    criteria=(
        "Determine whether the summary contains only information supported by "
        "the source text, with no contradictions or fabricated facts."
    ),
    evaluation_params=[
        LLMTestCaseParams.INPUT,
        LLMTestCaseParams.ACTUAL_OUTPUT,
    ],
    model=judge,
    threshold=0.7,
)


# --- 3. Boucle séquentielle sur le dataset ---
df = email_dataset  # ou pd.read_csv(...)

results = []
for idx, row in df.iterrows():
    test_case = LLMTestCase(
        input=row["text_X_cleaned"],
        actual_output=row["summary"],
    )

    summarization.measure(test_case)
    faithfulness.measure(test_case)

    results.append({
        "index": idx,
        "summarization_score": summarization.score,
        "summarization_reason": summarization.reason,
        "faithfulness_score": faithfulness.score,
        "faithfulness_reason": faithfulness.reason,
    })

results_df = pd.DataFrame(results)
print(results_df[["index", "summarization_score", "faithfulness_score"]])
results_df.to_csv("summary_eval_results.csv", index=False)
