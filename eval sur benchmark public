"""
Validate the is_usable() pre-ASR filter against a labelled speech-quality
dataset, and report precision / recall / F1 + confusion matrix.

Ground truth is derived by thresholding a human MOS label: a clip counts as
"not usable" (positive class) only when quality is very low, to match the
filter's job of rejecting *severe* corruption rather than mild degradation.
Keeping the MOS threshold low is deliberate - see the note in build_labels.

Run on your side (needs internet access to Hugging Face):
    pip install datasets scikit-learn librosa soundfile numpy
    python3 validate.py

Note: datasets are not model weights - load_dataset only downloads audio + CSV
labels, so this stays within the "no model weights" constraint.
"""

import numpy as np
from datasets import load_dataset, Audio
from sklearn.metrics import (
    precision_score, recall_score, f1_score,
    confusion_matrix, precision_recall_curve,
)
import audio_quality as aq

DATASET_ID = "urgent-challenge/urgent2024_mos"
MOS_FIELD = "mos"     # print(ds.column_names) once to confirm the exact name
SPLIT = "train"       # check available splits if this fails


def load_eval_dataset(sr=16000, max_samples=None):
    """Load a MOS-labelled dataset and force a common sample rate on the audio."""
    ds = load_dataset(DATASET_ID, split=SPLIT)
    ds = ds.cast_column("audio", Audio(sampling_rate=sr))
    if max_samples:
        ds = ds.select(range(min(max_samples, len(ds))))
    return ds


def run_filter(ds):
    """
    Run is_usable on each clip once.
    Returns: pred_bad (1 = filter says NOT usable), mos, harmonicity.
    We also keep harmonicity so we can draw a PR curve on a continuous score.
    """
    pred_bad, mos, harm = [], [], []
    for sample in ds:
        wav = np.asarray(sample["audio"]["array"], dtype=np.float32)
        sr = sample["audio"]["sampling_rate"]
        usable, _reasons, scores = aq.is_usable((wav, sr), return_details=True)
        pred_bad.append(0 if usable else 1)
        mos.append(sample[MOS_FIELD])
        harm.append(scores["harmonicity"])
    return np.array(pred_bad), np.array(mos, dtype=float), np.array(harm, dtype=float)


def build_labels(mos_values, mos_threshold):
    """
    Binary ground truth: 1 = "not usable" (very low MOS), 0 = usable.
    Keep the threshold LOW so the positive class matches truly-bad clips, not
    merely mediocre ones the filter is meant to pass. A high threshold makes the
    filter look bad for a reason that is really a label-definition mismatch.
    """
    return (np.asarray(mos_values) < mos_threshold).astype(int)


def report(y_true_bad, y_pred_bad):
    """Print precision / recall / F1 / confusion matrix for the 'not usable' class."""
    p = precision_score(y_true_bad, y_pred_bad, zero_division=0)
    r = recall_score(y_true_bad, y_pred_bad, zero_division=0)
    f1 = f1_score(y_true_bad, y_pred_bad, zero_division=0)
    cm = confusion_matrix(y_true_bad, y_pred_bad, labels=[0, 1])
    print(f"  positives (not-usable) in ground truth : {int(y_true_bad.sum())} / {len(y_true_bad)}")
    print(f"  precision : {p:.3f}   recall : {r:.3f}   f1 : {f1:.3f}")
    print(f"  confusion [rows=true 0/1, cols=pred 0/1]:\n{cm}")


def pr_curve_on_harmonicity(y_true_bad, harm):
    """
    Precision-recall trade-off using harmonicity as a continuous score.
    Harmonicity is LOW for bad audio, so the 'badness' score is -harmonicity.
    Prints a few operating points; swap in your own metric if you prefer.
    """
    bad_score = -harm
    prec, rec, thr = precision_recall_curve(y_true_bad, bad_score)
    print("  harmonicity_cutoff | precision | recall")
    # thr has one fewer element than prec/rec; sample a handful of points
    idx = np.linspace(0, len(thr) - 1, num=min(8, len(thr))).astype(int)
    for i in idx:
        print(f"    {-thr[i]:.3f}          |  {prec[i]:.3f}   | {rec[i]:.3f}")


def main():
    ds = load_eval_dataset(max_samples=None)
    print("columns:", ds.column_names)          # confirm MOS_FIELD name once
    pred_bad, mos, harm = run_filter(ds)

    # Sweep the ground-truth definition so you see how it moves the score.
    for thr in (1.5, 1.8, 2.2, 2.5):
        y_true_bad = build_labels(mos, thr)
        print(f"\n=== ground-truth: MOS < {thr} ===")
        report(y_true_bad, pred_bad)

    # Characterise the filter beyond its single operating point.
    print("\n=== PR curve on harmonicity (ground-truth MOS < 1.8) ===")
    pr_curve_on_harmonicity(build_labels(mos, 1.8), harm)


if __name__ == "__main__":
    main()
