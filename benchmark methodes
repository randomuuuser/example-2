"""
Audio corruption / quality metrics for pre-ASR filtering.

All metrics are weightless (pure signal processing, no model weights to load),
CPU-only, and run in well under a second per short clip. Each metric is a plain
function that takes a mono float32 waveform and returns a single scalar, so you
can pick and combine whichever ones discriminate best on your data.

Score directions (documented per function):
  higher = cleaner : snr_wada, snr_percentile, harmonicity, active_ratio, vad_speech_ratio
  higher = worse   : spectral_flatness, clipping_ratio, zero_crossing_rate
"""

import numpy as np
import librosa

EPS = 1e-10


# ----------------------------------------------------------------------------
# Loading / normalization
# ----------------------------------------------------------------------------

def load_audio(source, target_sr=16000):
    """
    Load audio from a file path (.wav/.mp3/...) or a raw numpy array.
    Always returns (mono float32 waveform, sample_rate).

    - Stereo is downmixed to mono by averaging channels.
    - Signal is resampled to target_sr.
    - For array input, pass source as (waveform, source_sr) tuple, or a bare
      array already at target_sr.
    """
    if isinstance(source, tuple):
        wav, sr = source
        wav = np.asarray(wav, dtype=np.float32)
    elif isinstance(source, np.ndarray):
        wav, sr = source.astype(np.float32), target_sr
    else:
        # File path: librosa handles wav/mp3, resampling and mono downmix.
        # mp3 decoding requires an audio backend (ffmpeg or libsndfile>=1.1).
        wav, sr = librosa.load(source, sr=target_sr, mono=True)
        return wav.astype(np.float32), sr

    # Downmix stereo arrays (shape [channels, n] or [n, channels]) to mono.
    if wav.ndim == 2:
        axis = 0 if wav.shape[0] < wav.shape[1] else 1
        wav = wav.mean(axis=axis)
    if sr != target_sr:
        wav = librosa.resample(wav, orig_sr=sr, target_sr=target_sr)
        sr = target_sr
    return wav.astype(np.float32), sr


# ----------------------------------------------------------------------------
# SNR estimators (blind, no clean reference)
# ----------------------------------------------------------------------------

# WADA-SNR gamma curve (shape=0.4), ported from johnmeade's public Python port
